# Comma-separated list of origins allowed to call the API
CORS_ORIGINS=http://localhost:3000

# Environment: development | production
APP_ENV=development

# Logging
LOG_LEVEL=INFO

# --- Persistence ---
# SQLite by default (a local file, no server to run). Alerts, AI chat sessions, and
# prediction history are stored here so they survive restarts. Swap for a Postgres URL
# if deploying somewhere with an ephemeral filesystem (a SQLite file won't survive a
# redeploy there).
DATABASE_URL=sqlite:///./market_mind.db

# --- Market data provider ---
# Live/historical quotes come from yfinance (the unofficial Yahoo Finance API). It has no
# authenticated REST endpoint, so there is no market-data API key to set here - Yahoo's
# quote/history endpoints have never required one. If a paid, key-authenticated vendor
# (Twelve Data, Finnhub, Polygon, etc.) is added later, it plugs in behind the
# `MarketDataProvider` interface in backend/data/provider.py without touching services/API
# layers, and its key would live in this file at that point.

# Seconds to cache quote/candle/history responses in memory before refetching. Every
# consumer of a symbol's data (dashboard, charts, indicators, predictions, risk, AI
# assistant) shares these cached values instead of each triggering its own Yahoo call.
QUOTE_CACHE_TTL_SECONDS=10
CANDLE_CACHE_TTL_SECONDS=30

# Seconds between pushes to each connected WebSocket client. Independent of how often the
# server actually polls Yahoo (see HUB_* below) - many clients watching the same symbol
# share one upstream poller, so this can safely stay at 1s without multiplying outbound
# requests per viewer.
WS_POLL_INTERVAL_SECONDS=1

# Max requests per symbol per minute, and across ALL symbols combined, before we return a
# rate-limit error to the client. The global limit exists because Yahoo's undocumented
# throttling is IP-wide, not per-symbol - a dashboard watching many symbols could stay
# under every individual symbol's quota while still tripping Yahoo's real limit.
PROVIDER_RATE_LIMIT_PER_MINUTE=60
PROVIDER_GLOBAL_RATE_LIMIT_PER_MINUTE=900

# Retry/backoff for transient network failures (DNS blips, dropped connections) when
# calling yfinance. Not for rate limiting - a real 429 from Yahoo is not retried; instead
# it trips a shared cooldown (below) so every symbol's poller backs off together.
PROVIDER_MAX_RETRIES=3
PROVIDER_RETRY_BASE_DELAY_SECONDS=0.5
PROVIDER_RATE_LIMIT_COOLDOWN_SECONDS=15.0

# --- Live update poller (services/live_hub.py) ---
# One background poller per actively-watched symbol, shared by every client subscribed to
# it - the cadence below is how often that poller calls yfinance for that symbol, and it
# adapts automatically to the symbol's own market session so we're not hammering Yahoo
# for a market that's closed and cannot move:
#   - HUB_QUOTE_INTERVAL_OPEN_SECONDS: while the market is open (fastest safe cadence -
#     yfinance has no true push/streaming API or documented rate limit, so 1s is a
#     conservative floor rather than a guaranteed "real-time" figure).
#   - HUB_QUOTE_INTERVAL_EXTENDED_SECONDS: pre-market / after-hours (prices move, but
#     much less actively than during the regular session).
#   - HUB_QUOTE_INTERVAL_CLOSED_SECONDS: fully closed (weekends, overnight) - the price
#     cannot change, so this can be slow.
HUB_QUOTE_INTERVAL_OPEN_SECONDS=1.0
HUB_QUOTE_INTERVAL_EXTENDED_SECONDS=5.0
HUB_QUOTE_INTERVAL_CLOSED_SECONDS=60.0
HUB_INDICATOR_INTERVAL_SECONDS=30
HUB_IDLE_SHUTDOWN_SECONDS=45
HUB_ERROR_BACKOFF_MAX_SECONDS=30

# AI Insights Assistant (Google Gemini). Leave GEMINI_API_KEY unset to use the built-in
# mock provider for local development - the feature works end-to-end without a key.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=20
AI_CHAT_RATE_LIMIT_PER_MINUTE=20
AI_MAX_HISTORY_MESSAGES=20
AI_RESPONSE_CACHE_TTL_SECONDS=30
