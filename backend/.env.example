# Comma-separated list of origins allowed to call the API
CORS_ORIGINS=http://localhost:3000

# Environment: development | production
APP_ENV=development

# Logging
LOG_LEVEL=INFO

# Seconds to cache quote/candle responses in memory before refetching
QUOTE_CACHE_TTL_SECONDS=10
CANDLE_CACHE_TTL_SECONDS=30

# Seconds between polls for the WebSocket live price stream
WS_POLL_INTERVAL_SECONDS=5

# Max requests per symbol per minute before we return a rate-limit error
PROVIDER_RATE_LIMIT_PER_MINUTE=60

# AI Insights Assistant (Google Gemini). Leave GEMINI_API_KEY unset to use the built-in
# mock provider for local development - the feature works end-to-end without a key.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=20
AI_CHAT_RATE_LIMIT_PER_MINUTE=20
AI_MAX_HISTORY_MESSAGES=20
